# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Data Source API Keys (optional — missing keys skip that source)
SERPER_API_KEY=your_serper_api_key_here
PRODUCT_HUNT_API_KEY=your_product_hunt_api_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
GITHUB_TOKEN=your_github_token_here

# Infrastructure
REDIS_URL=redis://localhost:6379/0
DB_PATH=noosphere.db
SOURCES_DB_PATH=noosphere_sources.db

# Job Settings
MAX_JOBS=5
SIM_QUEUE_TIMEOUT_SECONDS=900
SIM_HEARTBEAT_TIMEOUT_SECONDS=90

# Rate Limiter (optional)
OPENAI_RPM=500
OPENAI_RPM_SAFETY=0.80

# TPM limits (tokens per minute per provider, 80% safety 적용 전 원본 한도)
OPENAI_TPM=100000
